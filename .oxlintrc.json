{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn",
    "style": "off"
  },
  "rules": {
    "curly": "error",
    "no-await-in-loop": "off"
  },
  "ignorePatterns": ["node_modules", "packages/pi-sandbox/bin", ".pi", "tmp"]
}
