{
  "name": "pi-extensions",
  "version": "0.1.0",
  "description": "Personal extensions for the Pi agent harness.",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "pi-package",
    "pi-extensions"
  ],
  "pi": {
    "extensions": [
      "./packages/pi-caffeinate/src/index.ts",
      "./packages/pi-context-prune/src/index.ts",
      "./packages/pi-readonly/src/index.ts",
      "./packages/pi-guard/src/index.ts",
      "./packages/pi-sandbox/src/index.ts",
      "./packages/pi-footer/src/index.ts",
      "./packages/pi-auto-name/src/index.ts",
      "./packages/pi-implement/src/index.ts",
      "./packages/pi-codex-usage/src/index.ts",
      "./packages/pi-model-handoff/src/index.ts"
    ]
  },
  "scripts": {
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check": "npm run lint && npm run format:check && npm run typecheck && npm run test"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.75.4",
    "@earendil-works/pi-coding-agent": "^0.75.5",
    "@earendil-works/pi-tui": "^0.75.4",
    "@prettier/plugin-oxc": "^0.1.4",
    "@types/node": "^22.0.0",
    "@types/picomatch": "^4.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "oxlint": "^0.15.0",
    "prettier": "^3.4.2",
    "typebox": "^1.1.38",
    "typescript": "^5.6.0",
    "vitest": "^4.1.0"
  },
  "lint-staged": {
    "*.{ts,js,json}": [
      "oxlint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@tintinweb/pi-subagents": "^0.8.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "bundledDependencies": [
    "@tintinweb/pi-subagents"
  ]
}
